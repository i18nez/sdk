{
  "name": "i18nez-sdk",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/react/playground"
  ],
  "scripts": {
    "build": "bun run --filter '@i18nez/*' build",
    "test": "bun run --filter '@i18nez/*' test",
    "typecheck": "bun run --filter '@i18nez/*' typecheck",
    "link:all": "cd packages/core && bun link && cd ../react && bun link"
  }
}
