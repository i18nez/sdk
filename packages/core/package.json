{
  "name": "@i18nez/core",
  "version": "1.3.0",
  "description": "Framework-agnostic client for the i18nez translation API",
  "keywords": [
    "i18n",
    "translation",
    "locale",
    "l10n",
    "react",
    "typescript",
    "i18nez"
  ],
  "homepage": "https://i18nez.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i18nez/i18nez.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/i18nez/i18nez/issues",
  "author": "i18nez",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsdom": "^26.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
