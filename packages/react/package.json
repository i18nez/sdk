{
  "name": "@i18nez/react",
  "version": "1.3.0",
  "description": "React hooks and components for the i18nez translation API",
  "keywords": [
    "i18n",
    "translation",
    "locale",
    "l10n",
    "react",
    "react-hooks",
    "i18nez"
  ],
  "homepage": "https://i18nez.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i18nez/i18nez.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/i18nez/i18nez/issues",
  "author": "i18nez",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@i18nez/core": "^1.3.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^26.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
